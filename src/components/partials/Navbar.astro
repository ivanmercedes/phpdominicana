---
import { Linkedin, Youtube } from "@lucide/astro";
import logo from "../../assets/logo.svg";
import DiscordIcon from "../icons/DiscordIcon.astro";
import TwitterIcon from "../icons/TwitterIcon.astro";
---

<nav
  class="bg-white/80 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-50"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center space-x-3">
        <a href="/">
          <img src={logo.src} alt="Logo" class="w-48" />
        </a>
      </div>

      <div class="hidden md:flex items-center space-x-8">
        <a
          href="/"
          class="text-blue-600 font-medium border-b-2 border-blue-600 pb-1"
          >Inicio</a
        >
        <a
          href="#"
          class="text-gray-600 hover:text-gray-900 font-medium"
          >Sobre Nosotros</a
        >
        <a
          href="#"
          class="text-gray-600 hover:text-gray-900 font-medium">Proyectos</a
        >
        <a href="#" class="text-gray-600 hover:text-gray-900 font-medium"
          >Recursos</a
        >
        <a
          href="#"
          class="text-gray-600 hover:text-gray-900 font-medium">Contactos</a
        >
      </div>

      <div class="flex items-center space-x-3">
        <a
          href="#"
          class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-gray-200 transition-colors"
        >
          <TwitterIcon className="w-4 h-4 text-gray-600" />
        </a>
        <a
          href="#"
          class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-gray-200 transition-colors"
        >
          <Linkedin class="w-4 h-4 text-gray-600" />
        </a>
        <a
          href="#"
          class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-gray-200 transition-colors"
        >
          <Youtube class="w-4 h-4 text-gray-600" />
        </a>
        <a
          href="#"
          class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-gray-200 transition-colors"
        >
          <DiscordIcon className="w-4 h-4 text-gray-600" />
        </a>
      </div>
    </div>
  </div>
</nav>
