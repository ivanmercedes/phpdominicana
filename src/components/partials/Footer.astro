            ></path>
          </svg>
        </a> -->
        <!-- YouTube -->
        <a
          href="#"
          class="w-10 h-10 bg-gray-200 rounded-lg flex items-center justify-center hover:bg-gray-300 transition-colors"
        >
          <svg
            class="w-5 h-5 text-gray-600"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
