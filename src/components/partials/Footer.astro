      </div>

      <!-- Copyright and Links -->
      <div class="text-center md:text-right">
        <p class="text-sm text-gray-600 mb-2">
          © 2024 - PHP Dominicana - Términos y condiciones aplicables
        </p>
        <div
          class="flex flex-wrap justify-center md:justify-end space-x-4 text-sm text-gray-500"
        >
          <a href="#" class="hover:text-gray-700 transition-colors"
            >Política de Privacidad</a
          >
          <a href="#" class="hover:text-gray-700 transition-colors"
            >Términos de Servicio</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
