---
import { Code } from "astro:components";
---

<header class="relative overflow-x-hidden">
  <div class="absolute inset-0 overflow-x-hidden">
    <div
      class="absolute -top-40 -right-32 w-96 h-96 bg-gradient-to-br from-primary to-indigo-300 rounded-full opacity-60 blur-3xl"
    >
    </div>
    <div
      class="absolute top-20 -left-32 w-80 h-80 bg-gradient-to-br from-primary to-blue-300 rounded-full opacity-50 blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-96 h-96 bg-gradient-to-br from-indigo-200 to-blue-200 rounded-full opacity-40 blur-3xl"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16">
    <div class="text-center">
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight"
      >
        Bienvenidos a Nuestra<br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary"
          >Comunidad</span
        >
      </h1>

      <p
        class="text-lg md:text-xl text-gray-600 mb-12 max-w-3xl mx-auto leading-relaxed"
      >
        Somos la más grande comunidad de Desarrolladores PHP en la<br />
        República Dominicana ¡Ven y forma parte!
      </p>

      <div
        class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16"
      >
        <button
          class="bg-gradient-to-r from-primary to-secondary text-white px-8 py-4 rounded-full font-semibold text-lg hover:from-primary/90 hover:to-secondary/90 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1"
        >
          Recibe Nuestro Boletín
        </button>
        <button
          class="bg-white/80 backdrop-blur-sm text-gray-700 px-8 py-4 rounded-full font-semibold text-lg border border-gray-200 hover:bg-white hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1"
        >
          Conoce Más
        </button>
      </div>

      <div class="relative max-w-4xl mx-auto">
        <div
          class="bg-gray-900 rounded-2xl shadow-2xl overflow-hidden border border-gray-700"
        >
          <div class="bg-gray-800 px-4 py-3 flex items-center space-x-2">
            <div class="w-3 h-3 bg-red-500 rounded-full"></div>
            <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
            <div class="w-3 h-3 bg-green-500 rounded-full"></div>
            <div class="ml-4 text-gray-400 text-sm font-mono">welcome.php</div>
          </div>

          <div class="p-6 text-sm leading-relaxed text-left">
            <Code
              code={`<?php

declare(strict_types=1);

use ComunidadPhp\Dominicana;

$comunidad = new Dominicana();

$comunidad->unirte([
    'rol'    => 'Desarrollador PHP',
    'intereses' => ['Laravel','PHP',  'Open Source', 'Eventos', 'Café'],
]);

$comunidad->compartirConocimiento();
$comunidad->crearConexiones();

echo "🇩🇴 ¡Bienvenido a la Comunidad PHP Dominicana!";
`}
              lang="php"
              theme="dracula"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
