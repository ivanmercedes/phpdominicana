---
interface Props {
  componentName: string;
  port?: number;
}

const { componentName, port = 8000 } = Astro.props;

let htmlContent = "";
let error = null;

try {
  if (import.meta.env.SSR) {
    const response = await fetch(
      `http://localhost:${port}/index.php?component=${encodeURIComponent(componentName)}`
    );
    if (!response.ok) {
      throw new Error(
        `Failed to fetch PHP component: ${response.status} ${response.statusText}`
      );
    }
    htmlContent = await response.text();
  }
} catch (e: any) {
  console.error("Error fetching PHP component:", e);
  error = e.message || "Unknown error";
  htmlContent = `<p style="color: red;">Error loading PHP component: ${componentName}. Please ensure the PHP server is running on port ${port}.</p>`;
  if (import.meta.env.DEV) {
    htmlContent += `<p style="color: orange;">Details: ${error}</p>`;
  }
}
---

<div class="php-component-wrapper" set:html={htmlContent} />

<style>
  .php-component-wrapper {
    border: 1px dashed #ccc;
    padding: 1rem;
    margin-bottom: 1rem;
  }
  .php-component-wrapper h1 {
    margin-top: 0;
    color: #7a0099; /* PHP purple-ish */
  }
  .php-component-wrapper p {
    margin-bottom: 0;
  }
</style>
